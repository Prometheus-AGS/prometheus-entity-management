{
  "name": "@prometheus-ags/entity-graph-core",
  "version": "3.0.0-alpha.0",
  "description": "Framework-agnostic normalized entity graph store (zero React) — the core of the Prometheus entity-graph ecosystem.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@ag-ui/core": ">=0.0.30",
    "@tauri-apps/plugin-sql": ">=2.0.0",
    "loro-crdt": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@ag-ui/core": {
      "optional": true
    },
    "@tauri-apps/plugin-sql": {
      "optional": true
    },
    "loro-crdt": {
      "optional": true
    }
  },
  "dependencies": {
    "immer": ">=11",
    "zustand": ">=5"
  },
  "keywords": [
    "entity-graph",
    "normalized-cache",
    "state-management",
    "zustand",
    "framework-agnostic"
  ]
}
