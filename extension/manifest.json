{
  "manifest_version": 3,
  "name": "Prometheus Entity Explorer",
  "version": "0.1.0",
  "description": "DevTools panel for inspecting entity graph state in apps using @prometheus-ags/prometheus-entity-management",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "devtools_page": "devtools.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
