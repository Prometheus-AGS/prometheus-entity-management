# Provenance (SLSA attestations) only works from supported CI with OIDC (e.g. GitHub Actions).
# `provenance=true` breaks local `pnpm publish` with: Automatic provenance generation not supported for provider: null
provenance=false

# Ensure the package is published to the public registry
access=public

# Lock exact versions for devDependencies installs in CI
# (consumers get semver ranges as declared in package.json)
save-exact=false
