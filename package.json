{
  "name": "@prometheus-ags/entity-graph-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace manager for the Prometheus entity-graph ecosystem (pnpm + Turborepo + Changesets). Not published — see packages/* for the published packages.",
  "author": "Travis James <travis@prometheus.dev>",
  "license": "MIT",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "refresh:exports": "pnpm --filter @prometheus-ags/prometheus-entity-management run refresh:exports",
    "verify:skills": "pnpm --filter @prometheus-ags/prometheus-entity-management run verify:skills",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "dev:vite": "pnpm --filter prometheus-entity-management-vite dev",
    "dev:next": "pnpm --filter prometheus-entity-management-nextjs dev",
    "clean": "find . -name 'node_modules' -type d -not -path '*/\\.*' | xargs rm -rf && find . -name 'dist' -o -name '.next' | xargs rm -rf"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": ">=19",
    "@types/react-dom": ">=19",
    "@vitest/browser": "^4.1.7",
    "better-sqlite3": "^12.11.1",
    "jsdom": "^29.1.1",
    "loro-crdt": "^1.13.6",
    "tsup": ">=8",
    "turbo": "^2.9.18",
    "typescript": ">=6",
    "vitest": ">=4"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a304c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
