{
  "name": "@prometheus-ags/prometheus-entity-management",
  "version": "2.2.0",
  "description": "Normalized, globally-reactive entity graph store for React — replaces TanStack Query's per-view cache model with a single application-wide entity graph built on Zustand.",
  "author": "Travis James <travis@prometheus.dev>",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "workspaces": [
    "examples/vite-app",
    "examples/nextjs-app"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "refresh:exports": "pnpm run build && node scripts/refresh-exports-ledger.mjs",
    "verify:skills": "node scripts/verify-skills-exports.mjs",
    "check:treeshake": "node -e \"const s=require('fs').readFileSync('src/graph-actions.ts','utf8');if(!s.includes('process.env.NODE_ENV !=='))throw new Error('devtools leak detected: NODE_ENV guard missing in graph-actions.ts');console.log('treeshake gate: OK');\"",
    "prepublishOnly": "pnpm run check:treeshake && pnpm run typecheck && pnpm run build && pnpm run test && pnpm run verify:skills",
    "dev:vite": "pnpm --filter prometheus-entity-management-vite dev",
    "dev:next": "pnpm --filter prometheus-entity-management-nextjs dev",
    "build:vite": "pnpm --filter prometheus-entity-management-vite build",
    "build:next": "pnpm --filter prometheus-entity-management-nextjs build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:vite": "tsc --noEmit -p examples/vite-app/tsconfig.json",
    "typecheck:next": "tsc --noEmit -p examples/nextjs-app/tsconfig.json",
    "clean": "find . -name 'node_modules' -type d -not -path '*/\\.*' | xargs rm -rf && find . -name 'dist' -o -name '.next' | xargs rm -rf"
  },
  "peerDependencies": {
    "@ag-ui/core": ">=0.0.30",
    "@tanstack/react-table": ">=8.0.0",
    "@tauri-apps/plugin-sql": ">=2.0.0",
    "loro-crdt": ">=1.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@ag-ui/core": {
      "optional": true
    },
    "@tanstack/react-table": {
      "optional": true
    },
    "@tauri-apps/plugin-sql": {
      "optional": true
    },
    "loro-crdt": {
      "optional": true
    }
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.26",
    "clsx": ">=2",
    "immer": ">=11",
    "lucide-react": ">=1",
    "tailwind-merge": ">=3",
    "zustand": ">=5"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": ">=19",
    "@types/react-dom": ">=19",
    "@vitest/browser": "^4.1.7",
    "jsdom": "^29.1.1",
    "tsup": ">=8",
    "typescript": ">=6",
    "vitest": ">=4"
  },
  "keywords": [
    "react",
    "state-management",
    "entity-graph",
    "normalized-cache",
    "zustand",
    "realtime",
    "tanstack-query-alternative",
    "graphql",
    "supabase",
    "electricsql",
    "pglite",
    "local-first"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/prometheus-ags/prometheus-entity-management"
  },
  "bugs": {
    "url": "https://github.com/prometheus-ags/prometheus-entity-management/issues"
  },
  "homepage": "https://github.com/prometheus-ags/prometheus-entity-management#readme",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a304c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
